{
  "name": "nexnote",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm --filter @nexnote/shared build && pnpm --filter @nexnote/db build && pnpm --filter @nexnote/api --filter @nexnote/worker --filter @nexnote/web --parallel build",
    "lint": "pnpm -r run lint",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "typescript": "^5.8.0"
  }
}
