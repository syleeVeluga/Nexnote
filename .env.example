# PostgreSQL
DATABASE_URL=postgresql://wekiflow:wekiflow@localhost:5432/wekiflow
POSTGRES_USER=wekiflow
POSTGRES_PASSWORD=wekiflow
POSTGRES_DB=wekiflow

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# MinIO (Object Storage)
MINIO_ROOT_USER=wekiflow
MINIO_ROOT_PASSWORD=wekiflow-dev-secret
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=wekiflow
S3_SECRET_KEY=wekiflow-dev-secret
S3_BUCKET=wekiflow-ingestions
S3_REGION=us-east-1

# API server
API_PORT=3001
API_HOST=0.0.0.0

# Frontend dev server
WEB_PORT=5173

# AI providers
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
REFORMAT_OPENAI_MODEL=gpt-5.4-mini
REFORMAT_GEMINI_MODEL=gemini-3.1-flash-lite-preview
PREDICATE_LABEL_OPENAI_MODEL=gpt-5.4-mini
PREDICATE_LABEL_GEMINI_MODEL=gemini-3.1-flash-lite-preview

# JWT / Auth
JWT_SECRET=change-me-in-production

# Environment
NODE_ENV=development

# Ingestion guardrails
# Per-API-token burst limit (fixed window, seconds=60)
INGESTION_RATE_LIMIT_PER_MINUTE=60
# Per-workspace daily quota (fixed window, seconds=86400)
INGESTION_QUOTA_PER_DAY=5000

# Slack Events API webhook (POST /api/v1/webhooks/slack/events)
# Slack App > Basic Information > Signing Secret
SLACK_SIGNING_SECRET=
# Slack App > OAuth & Permissions > Bot Token (xoxb-...)
# Required scope: channels:history
SLACK_BOT_TOKEN=
# HR 채널 ID — 미답변 질문이 전달되는 Slack 채널
SLACK_HR_CHANNEL_ID=C0AUVER6M5X
# 봇 메시지 필터링용 봇 유저 ID
SLACK_BOT_USER_ID=U0AUG7B5CTC
# 수집 대상 WekiFlow 워크스페이스 UUID (GET /api/v1/workspaces 로 확인)
SLACK_WEKIFLOW_WORKSPACE_ID=
# 수집 작업 귀속 WekiFlow 유저 UUID (POST /api/v1/auth/login 응답의 user.id)
SLACK_WEKIFLOW_USER_ID=
