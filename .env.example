# PostgreSQL
DATABASE_URL=postgresql://nexnote:nexnote@localhost:5432/nexnote

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# API server
API_PORT=3001
API_HOST=0.0.0.0

# Frontend dev server
WEB_PORT=5173

# AI providers
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
REFORMAT_OPENAI_MODEL=gpt-5.4-mini
REFORMAT_GEMINI_MODEL=gemini-3.1-flash-lite
PREDICATE_LABEL_OPENAI_MODEL=gpt-5.4-mini
PREDICATE_LABEL_GEMINI_MODEL=gemini-3.1-flash-lite

# JWT / Auth
JWT_SECRET=change-me-in-production

# Environment
NODE_ENV=development

# Ingestion guardrails
# Per-API-token burst limit (fixed window, seconds=60)
INGESTION_RATE_LIMIT_PER_MINUTE=60
# Per-workspace daily quota (fixed window, seconds=86400)
INGESTION_QUOTA_PER_DAY=5000
